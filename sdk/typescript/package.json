{
  "name": "sirenic-agents",
  "version": "0.1.0",
  "description": "LangChain.js tools for Sirenic — official French & European company data, paid per call via x402 (USDC/EURC on Base). No account, no API key: bring a wallet key, set a price cap, done.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sirenic-eu/sirenic-examples",
    "directory": "sdk/typescript"
  },
  "keywords": ["langchain", "x402", "kyb", "france", "company-data", "agents", "sirenic"],
  "peerDependencies": {
    "@langchain/core": "^1.0.0"
  },
  "dependencies": {
    "@x402/core": "^2.18.0",
    "@x402/evm": "^2.18.0",
    "@x402/fetch": "^2.18.0",
    "viem": "^2.21.0",
    "zod": "^3.25.76 || ^4.0.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.2.3",
    "typescript": "^5.6.0"
  }
}
